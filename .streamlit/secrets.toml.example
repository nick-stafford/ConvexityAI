# Template for Streamlit secrets.
# For LOCAL dev: copy this file to `.streamlit/secrets.toml` and fill in your key.
# For Streamlit Community Cloud: paste these lines into
#   App -> Settings -> Secrets  (do NOT commit the real key).

GROQ_API_KEY = "your_groq_api_key_here"

# Optional. Only needed if you want AI image generation (Nano Banana).
# GEMINI_API_KEY = "your_gemini_api_key_here"
